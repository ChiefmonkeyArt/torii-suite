# torii-suite — bootstrap environment
#
# Two ways to configure:
#
#   A) One-liner install: no .env needed. bootstrap.sh asks the three required
#      questions (domain, LE email, admin npub) on first run and writes the
#      answers to /opt/torii-suite/checkout/.env for you. Re-runs pick it up.
#
#   B) Manual: copy this file to .env, fill it in, then: sudo -E ./bootstrap.sh
#
# Only TORII_DOMAIN, LETSENCRYPT_EMAIL, and CONTINUUM_ADMIN_NPUB are required.
# The rest have sensible defaults.

# ---------- REQUIRED ----------

# Fully-qualified domain pointing at this VPS (single A record).
# Apps are mounted at sub-paths on this domain (see README §Topology).
TORII_DOMAIN=torii.example.com

# Email address for Let's Encrypt (free HTTPS certificates).
# Only used for cert-expiry warnings if auto-renewal ever fails. Any working
# inbox is fine — it doesn't have to match your domain.
LETSENCRYPT_EMAIL=you@example.com

# Your admin npub (bech32). The continuum agent authenticates YOU against this.
# NEVER put an nsec here — the VPS does not sign anything. Get your npub from
# your NIP-07 signer (Plebeian Signer, nos2x, etc.).
CONTINUUM_ADMIN_NPUB=npub1exampleexampleexampleexampleexampleexampleexampleexampleee

# ---------- OPT-IN APPS (default: install all four) ----------

INSTALL_CONTINUUM=1
INSTALL_QUEST=1
INSTALL_PLEBEIAN=1  # registers a launcher tile only — see README §Plebeian

# Local Ollama LLM daemon, used as a fallback when Routstr is unreachable or
# out of ecash. On a CPU-only VPS expect 1–5 tok/s from the default 3B model —
# usable, not a daily driver. If you already run Ollama somewhere beefier
# (homelab GPU, Tailscale LAN, private VPS), set OLLAMA_MODE=remote + OLLAMA_URL
# below and keep INSTALL_OLLAMA=1 — the suite skips the local install and
# wires Continuum at your existing endpoint.
# Automatically disabled when INSTALL_CONTINUUM=0 (nothing would consume it).
INSTALL_OLLAMA=1

# Onboarding bridges (CORS proxy + WebSSH). Default OFF: only turn on if you
# plan to run the browser-side non-coder onboarding flow against this host.
# Once enabled, both bridges run on this VPS behind nginx and are exposed at
# /cors-proxy/... and /webssh (see docs/ONBOARDING_ARCHITECTURE.md).
INSTALL_ONBOARDING_BRIDGES=0

# ---------- ONBOARDING BRIDGES (only used when INSTALL_ONBOARDING_BRIDGES=1) ----------

# Comma-separated list of browser origins allowed to call the CORS proxy.
# The proxy REFUSES to start on an empty allowlist — you must set this.
# Example: https://onboarding.example.com,https://torii.example.com
CORS_PROXY_ORIGIN_ALLOW=

# Comma-separated list of upstream hostnames the CORS proxy will forward to.
# Requests to any host not in this list are rejected with 403. Empty = refuse
# to start. Default is the SHC API host — change or extend for other providers.
CORS_PROXY_UPSTREAM_ALLOW=blesta.sovereignhybridcompute.com

# Local port for the CORS proxy (nginx reverse-proxies to it on 127.0.0.1).
CORS_PROXY_PORT=8801

# Comma-separated list of browser origins allowed to open the WebSSH socket.
# Empty = refuse to start.
WEBSSH_ORIGIN_ALLOW=

# Local port for the WebSSH bridge (nginx wss:// upgrade proxied to it).
WEBSSH_PORT=8802

# Max simultaneous WebSSH sessions per source IP.
WEBSSH_MAX_PER_IP=3

# Hard cap on a single WebSSH session's lifetime, in milliseconds (default 15m).
WEBSSH_MAX_SESSION_MS=900000

# ---------- OPTIONAL ----------

# Skip Let's Encrypt (useful for local testing / staging behind another proxy).
SKIP_CERTBOT=0

# Override the working directory. Defaults to /opt/torii-suite/work.
SUITE_WORK_DIR=/opt/torii-suite/work

# Git refs to install. Defaults to `main` for each. Pin to a tag for reproducible
# installs (e.g. TORII_CONTINUUM_REF=v0.2.10-alpha).
TORII_BASE_REF=main
TORII_CONTINUUM_REF=main
TORII_QUEST_REF=main

# Where the continuum agent listens locally (proxied by nginx). Change only if
# port 8787 collides with something else on your host.
CONTINUUM_AGENT_PORT=8787

# External URL for the plebeian marketplace tile (registered only, not installed).
PLEBEIAN_EXTERNAL_URL=https://plebeian.market

# ---------- OLLAMA (only used when INSTALL_OLLAMA=1) ----------

# Two modes:
#   local   — install Ollama on this VPS, bind loopback, pull models locally.
#             Best when the VPS has >= 4 GB RAM to spare. CPU-only — usable
#             as a fallback, not a daily driver.
#   remote  — skip the install and point Continuum at an existing Ollama
#             endpoint you already run somewhere else (homelab GPU box,
#             Tailscale/WireGuard LAN, private VPS). Preflight-probes the
#             endpoint before touching anything.
OLLAMA_MODE=local

# Bind address for the local Ollama daemon (OLLAMA_MODE=local only).
# Loopback-only by default so the daemon is not exposed on the public
# interface. Only change if you know what you're doing (e.g. binding to a
# WireGuard interface for a private LAN).
OLLAMA_BIND=127.0.0.1:11434

# URL of the remote Ollama endpoint (OLLAMA_MODE=remote only).
# Examples:
#   http://10.0.0.5:11434                    (RFC1918 LAN — fine over plaintext)
#   http://ollama-box.tailnet.ts.net:11434   (Tailscale/WireGuard — fine)
#   https://ollama.example.com               (public endpoint behind TLS + auth)
# Plaintext http:// to a public host emits a warning — inference traffic is
# in the clear. Prefer https:// or a private-network address.
OLLAMA_URL=

# Optional: full HTTP header line for authenticating against a reverse-proxy
# in front of the remote endpoint. Example:
#   OLLAMA_AUTH_HEADER="Authorization: Bearer sk-<token>"
# Written to the Continuum agent config at mode 0600. Leave empty for
# endpoints without auth (private LAN / Tailscale).
OLLAMA_AUTH_HEADER=

# Space-separated list of models to pull on install (OLLAMA_MODE=local only).
# Defaults to a single 3B model that fits comfortably on a 4 GB VPS. Add
# larger models here if you have the RAM — e.g. "llama3.2:3b qwen2.5:7b".
OLLAMA_MODELS=llama3.2:3b
