# torii-suite — bootstrap environment
# Copy to .env, fill in, then: sudo -E ./bootstrap.sh
#
# Only TORII_DOMAIN, LETSENCRYPT_EMAIL, and CONTINUUM_ADMIN_NPUB are required.
# The rest have sensible defaults.

# ---------- REQUIRED ----------

# Fully-qualified domain pointing at this VPS (single A record).
# Apps are mounted at sub-paths on this domain (see README §Topology).
TORII_DOMAIN=torii.example.com

# Email address used for Let's Encrypt account registration.
LETSENCRYPT_EMAIL=you@example.com

# Your admin npub (bech32). The continuum agent authenticates YOU against this.
# NEVER put an nsec here — the VPS does not sign anything. Get your npub from
# your NIP-07 signer (Plebeian Signer, nos2x, etc.).
CONTINUUM_ADMIN_NPUB=npub1exampleexampleexampleexampleexampleexampleexampleexampleee

# ---------- OPT-IN APPS (default: install all three) ----------

INSTALL_CONTINUUM=1
INSTALL_QUEST=1
INSTALL_PLEBEIAN=1  # registers a launcher tile only — see README §Plebeian

# Onboarding bridges (CORS proxy + WebSSH). Default OFF: only turn on if you
# plan to run the browser-side non-coder onboarding flow against this host.
# Once enabled, both bridges run on this VPS behind nginx and are exposed at
# /cors-proxy/... and /webssh (see docs/ONBOARDING_ARCHITECTURE.md).
INSTALL_ONBOARDING_BRIDGES=0

# ---------- ONBOARDING BRIDGES (only used when INSTALL_ONBOARDING_BRIDGES=1) ----------

# Comma-separated list of browser origins allowed to call the CORS proxy.
# The proxy REFUSES to start on an empty allowlist — you must set this.
# Example: https://onboarding.example.com,https://torii.example.com
CORS_PROXY_ORIGIN_ALLOW=

# Comma-separated list of upstream hostnames the CORS proxy will forward to.
# Requests to any host not in this list are rejected with 403. Empty = refuse
# to start. Default is the SHC API host — change or extend for other providers.
CORS_PROXY_UPSTREAM_ALLOW=blesta.sovereignhybridcompute.com

# Local port for the CORS proxy (nginx reverse-proxies to it on 127.0.0.1).
CORS_PROXY_PORT=8801

# Comma-separated list of browser origins allowed to open the WebSSH socket.
# Empty = refuse to start.
WEBSSH_ORIGIN_ALLOW=

# Local port for the WebSSH bridge (nginx wss:// upgrade proxied to it).
WEBSSH_PORT=8802

# Max simultaneous WebSSH sessions per source IP.
WEBSSH_MAX_PER_IP=3

# Hard cap on a single WebSSH session's lifetime, in milliseconds (default 15m).
WEBSSH_MAX_SESSION_MS=900000

# ---------- OPTIONAL ----------

# Skip Let's Encrypt (useful for local testing / staging behind another proxy).
SKIP_CERTBOT=0

# Override the working directory. Defaults to /opt/torii-suite/work.
SUITE_WORK_DIR=/opt/torii-suite/work

# Git refs to install. Defaults to `main` for each. Pin to a tag for reproducible
# installs (e.g. TORII_CONTINUUM_REF=v0.2.10-alpha).
TORII_BASE_REF=main
TORII_CONTINUUM_REF=main
TORII_QUEST_REF=main

# Where the continuum agent listens locally (proxied by nginx). Change only if
# port 8787 collides with something else on your host.
CONTINUUM_AGENT_PORT=8787

# External URL for the plebeian marketplace tile (registered only, not installed).
PLEBEIAN_EXTERNAL_URL=https://plebeian.market
